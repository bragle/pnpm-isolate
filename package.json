{
  "name": "pnpm-isolate",
  "version": "1.0.0",
  "description": "Temporarily isolate a pnpm workspace to a selected package subset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bragle/pnpm-isolate.git"
  },
  "type": "module",
  "bin": {
    "pnpm-isolate": "dist/pnpm-isolate.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup pnpm-isolate.ts --format esm --platform node --target node20 --out-dir dist",
    "test": "node --test",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@pnpm/find-workspace-dir": "1000.1.5",
    "@pnpm/lockfile.fs": "1001.1.32",
    "@pnpm/lockfile.pruner": "1001.0.27",
    "@pnpm/workspace.projects-filter": "1000.0.43",
    "@pnpm/workspace.read-manifest": "1000.3.1",
    "js-yaml": "4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.5.2",
    "tsup": "8.5.1",
    "typescript": "6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}